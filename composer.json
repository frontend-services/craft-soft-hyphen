{
  "name": "frontend-services/craft-soft-hyphen",
  "description": "Adds a soft hyphen (&amp;shy;) and non breaking space (&amp;nbsp;) button to CKEditor in Craft CMS",
  "type": "craft-plugin",
  "version": "1.1.2",
  "license": "proprietary",
  "support": {
    "email": "mato@frontend.services",
    "issues": "https://github.com/frontend-services/craft-soft-hyphen/issues?state=open",
    "source": "https://github.com/frontend-services/craft-soft-hyphen",
    "docs": "https://github.com/frontend-services/craft-soft-hyphen",
    "rss": "https://github.com/frontend-services/craft-soft-hyphen/releases.atom"
  },
  "require": {
    "php": "^8.0",
    "craftcms/cms": "^4.0.0 || ^5.0.0",
    "craftcms/ckeditor": "^4.0|^5.0"
  },
  "autoload": {
    "psr-4": {
      "frontendservices\\softhyphen\\": "src/"
    }
  },
  "extra": {
    "handle": "soft-hyphen",
    "name": "Soft Hyphen",
    "developer": "frontend.services",
    "developerUrl": "https://github.com/frontend-services",
    "class": "frontendservices\\softhyphen\\Plugin"
  }
}